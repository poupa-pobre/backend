# Produção — copie para `.env.production` e preencha. NUNCA versione o .env.production.
#   cp .env.production.example .env.production

# --- Django ------------------------------------------------------------------
DEBUG=False
# Gere uma chave nova: python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
# Domínios que servem a API (sem esquema). O nome do serviço `api` cobre health checks internos.
ALLOWED_HOSTS=api.poupapobre.com.br,api
# Origens https confiáveis para o CSRF do admin (com esquema).
CSRF_TRUSTED_ORIGINS=https://api.poupapobre.com.br

# --- Banco (Postgres) --------------------------------------------------------
POSTGRES_DB=financas
POSTGRES_USER=financas
POSTGRES_PASSWORD=troque-por-uma-senha-forte
# Nome do serviço no compose; resolvido pela rede interna `backend`.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- CORS (clientes mobile/web) ---------------------------------------------
# CSV das origens liberadas em produção (em DEBUG tudo é liberado).
CORS_ALLOWED_ORIGINS=https://app.poupapobre.com.br

# --- Email (recuperação de senha — RF-001) ----------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.seu-provedor.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=usuario-smtp
EMAIL_HOST_PASSWORD=senha-smtp
DEFAULT_FROM_EMAIL=no-reply@poupapobre.com.br
FRONTEND_PASSWORD_RESET_URL=https://app.poupapobre.com.br/reset-senha

# --- Scanner de cupom / NFC-e ------------------------------------------------
NFCE_FETCH_ENABLED=True
NFCE_FETCH_TIMEOUT=8

# --- Gunicorn (opcional) -----------------------------------------------------
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
